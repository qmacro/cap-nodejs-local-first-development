#!/usr/bin/env bash

clearmsgbox() {
  echo > "$HOME/.cds-msg-box"
}

monmsgbox() {
  watch cat "$HOME/.cds-msg-box"
}

clearservices() {
  echo > "$HOME/.cds-services.json"
}

monservices() {
  watch -c jq -C . "$HOME/.cds-services.json"
}

sendaction() {

  local port="${1:-4006}"
  data="$(date +%s)" # random data

  curl \
    --request POST \
    --url "localhost:$port/rest/emitter/greet" \
    --data '{"greeting":"'"${data}"'"}'
}

main() {

  local util=$1
  shift
  if [[ -z $util ]]; then
    declare -F | sed 's/^declare -f //'
  else
    "$util" "$@"
  fi

}

main "$@"
